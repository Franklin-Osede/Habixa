# ============================================================
# Habixa API — environment variables (example)
# ============================================================
# Copy this file to `.env` and fill in real values.
# Never commit `.env` (it is gitignored).

# --- Database (Supabase Postgres or local Postgres) ---
# Supabase: Dashboard > Connect > ORMs > Prisma
#   - "Direct connection" (port 5432) for development.
#   - "Transaction pooler" (port 6543) for production runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
# Optional: only needed if DATABASE_URL is the pooled URL and you want
# Prisma migrations to use a direct (non-pooled) connection.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Server / queue ---
PORT=3008
REDIS_PORT=6380
# REDIS_HOST=127.0.0.1

# --- Auth ---
# JWT_SECRET=replace-with-a-long-random-string
# JWT_EXPIRES_IN=7d

# --- OpenAI ---
# Used by recipe / exercise seed scripts and the AI coach (default).
OPENAI_API_KEY=

# --- Coach provider switch (Phase 6) ---
# "openai" (default) -> OpenAiCoachLlm using $OPENAI_API_KEY
# "anthropic"        -> AnthropicCoachLlm using $ANTHROPIC_API_KEY
COACH_PROVIDER=openai
# COACH_MODEL=gpt-4o-mini

# --- Anthropic (only if COACH_PROVIDER=anthropic) ---
# ANTHROPIC_API_KEY=

# --- AWS (Polly TTS for Phase 7 voice cues) ---
# Scope the IAM user tightly: polly:SynthesizeSpeech +
# s3:PutObject on the voice bucket only.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Supabase Storage (Phase 7 audio cue uploads) ---
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
VOICE_AUDIO_BUCKET=habixa-voice

# Per-IP daily cap on AI lifestyle-plan generation (defaults to 2 if unset)
PLAN_GEN_DAILY_LIMIT=2

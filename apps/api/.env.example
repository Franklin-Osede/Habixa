# ============================================================
# Habixa API - Environment Variables Example
# ============================================================
# Copy this file to `.env` and fill in real values.
# Never commit `.env` (it is gitignored).
# ============================================================

# --- Database (Supabase Postgres or local Postgres) ---
# Supabase: get from Dashboard > Connect > ORMs > Prisma
#   - Use the "Direct connection" URI (port 5432) for development.
#   - Use the "Transaction pooler" URI (port 6543) for production runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
# Optional: only needed if you use a pooled DATABASE_URL and want
# Prisma migrations to use a direct (non-pooled) connection.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Server ---
PORT=3008

# --- Redis (for BullMQ planning queue) ---
REDIS_PORT=6380
# REDIS_HOST=127.0.0.1

# --- Auth ---
# JWT_SECRET=replace-with-a-long-random-string
# JWT_EXPIRES_IN=7d

# --- OpenClaw / AI providers (only required for Phase 6+) ---
# OPENCLAW_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Supabase Storage (only required when uploading media) ---
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
